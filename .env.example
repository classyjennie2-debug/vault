# Required Environment Variables for Vault Capital App

# JWT Secret for authentication (generate with: openssl rand -hex 32)
JWT_SECRET=your_secure_jwt_secret_here

# Database URL for PostgreSQL (use Vercel Postgres or Neon).
#
# Note: recent versions of the `pg` driver emit a warning when sslmode is
# set to `require`, `prefer`, or `verify-ca` because they will be treated as
# aliases for `verify-full` in pg v9+.  To suppress the warning and ensure
# you get the same security guarantees as today, explicitly use
# `sslmode=verify-full` (or add `uselibpqcompat=true&sslmode=require`
# if you prefer the older libpq semantics).
#
# Example:
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=verify-full

# App URL for production (your Vercel domain)
NEXT_PUBLIC_APP_URL=https://vaultinvest.vercel.app

# Crypto API Keys for price data (used by server-side only)
# Get from: https://coinmarketcap.com/api/
CMC_API_KEY=your_cmc_api_key_here

# Optional: Tawk.to Live Chat Integration
NEXT_PUBLIC_TAWK_PROPERTY_ID=69b21503801efb1c38c6c489
